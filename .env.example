# ── Dashboard & API server ────────────────────────────────────────────────────
# Host port for the React dashboard (nginx, container always listens on 80)
DASHBOARD_PORT=3000
# Host port for the Node.js api-server that backs the dashboard
API_SERVER_PORT=3001

# ── FastAPI complaint-service database (SQLite) ───────────────────────────────
# Used by the Python FastAPI service only. SQLite file path inside the container.
# The Node api-server uses a separate PostgreSQL database (see docker-compose.yml).
DATABASE_URL=sqlite:////app/data/complaints.db
LOG_LEVEL=INFO
SQL_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ── PostgreSQL (Evolution API v2 database) ────────────────────────────────────
# Password for the internal 'evolution' Postgres user.
# The DB name and user are fixed as 'evolution' (see docker-compose.yml).
EVOLUTION_DB_PASSWORD=change-me-db-pass

# ── Evolution API (self-hosted WhatsApp gateway) ──────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
# Public-facing URL of Evolution API (used by Evolution to know its own address)
EVOLUTION_SERVER_URL=http://localhost:8080
# API key — must match AUTHENTICATION_API_KEY in docker-compose.yml
EVOLUTION_API_KEY=change-me-strong-key-123
# Instance name — created automatically on first run
EVOLUTION_INSTANCE=complaint-bot
# HTTP timeout in seconds for Evolution API calls
EVOLUTION_TIMEOUT=10

# ── AI Classifier (GROQ) ──────────────────────────────────────────────────────
# Leave blank to use the built-in keyword classifier (no API key needed)
GROQ_API_KEY=
# Default model — llama-3.1-8b-instant is fast and free-tier friendly
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant

# ── OpenAI Integration (api-server AI features) ───────────────────────────────
# Base URL of the OpenAI-compatible endpoint used by the Node.js api-server.
# Use https://api.openai.com/v1 for OpenAI, or point to a local/compatible provider.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# API key for the above endpoint (required)
AI_INTEGRATIONS_OPENAI_API_KEY=
# Model to use for the AI chat feature (must be supported by the above endpoint)
# Groq models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# OpenAI models: gpt-4o, gpt-4o-mini
AI_MODEL=llama-3.3-70b-versatile

# ── OpenClaw Integration ───────────────────────────────────────────────────────
# Base URL of your OpenClaw instance
OPENCLAW_API_URL=https://api.openclaw.io
# API key for authenticating with OpenClaw (required to send reply messages)
OPENCLAW_API_KEY=
# Timeout in seconds for OpenClaw API calls
OPENCLAW_TIMEOUT=10

# ── Policy Engine ─────────────────────────────────────────────────────────────
# Set to true to disable all ticket creation and WhatsApp replies (log-only mode)
READ_ONLY_MODE=false

# Minimum AI confidence score required to create a ticket (0-1, default 0.7)
MIN_CONFIDENCE=0.7

# Send a polite reply even to non-complaint messages (default false)
ALLOW_CASUAL_REPLIES=false

# Hard-reject messages longer than this (characters)
MAX_MESSAGE_LENGTH=2000

# Comma-separated sender IDs/phones to allow, or * for all
ALLOWED_SENDERS=*

# Comma-separated keywords — messages containing any of these are rejected entirely
# Example: BLOCK_KEYWORDS=test,spam,advertisement
BLOCK_KEYWORDS=

# ── Daily Report Scheduler ────────────────────────────────────────────────────
# WhatsApp group ID that receives the daily report (required to actually send)
REPORT_GROUP_ID=
# Time to send the report in 24h format (default: 20:00 = 8 PM)
REPORT_CRON_HOUR=20
REPORT_CRON_MINUTE=0
# Timezone for the cron schedule — use any tz database name
# Examples: Asia/Karachi, Asia/Dubai, Asia/Kolkata, UTC, Europe/London
REPORT_TIMEZONE=Asia/Karachi

# ── Group Filtering ────────────────────────────────────────────────────────────
# Comma-separated list of allowed WhatsApp group IDs or group names.
# Accepts group IDs (e.g. 120363000000000001@g.us) or plain group names.
# Set to * or leave empty to allow ALL groups.
#
# Examples:
#   ALLOWED_GROUPS=*
#   ALLOWED_GROUPS=120363000000000001@g.us,120363000000000002@g.us
#   ALLOWED_GROUPS=Block B Residents,Tower A Complaints
ALLOWED_GROUPS=*

# ── Webhook Configuration ─────────────────────────────────────────────────────
# The URL Evolution API will send webhooks to
WEBHOOK_URL=http://api-server:3001/api/webhooks/evolution
# The URL of the FastAPI complaint-service to forward webhooks to
COMPLAINT_SERVICE_URL=http://api:8000

# ── Knowledge Engine Service ──────────────────────────────────────────────────
# Base URL of the knowledge-service (used by complaint-service)
KNOWLEDGE_SERVICE_URL=http://knowledge-service:8000

# Embedding provider: gemini | openai | groq | generic
EMBEDDING_PROVIDER=gemini

# API key for the selected embedding provider
# - Gemini:  your Google AI Studio API key
# - OpenAI:  your OpenAI secret key (sk-...)
# - Groq:    your Groq API key (gsk_...)
# - Generic: whatever key the compatible endpoint requires
EMBEDDING_API_KEY=
# Google Drive API key — required for Research Hub (NotebookLM style features)
GOOGLE_DRIVE_API_KEY=

# Base URL of the embedding endpoint — change when switching providers:
#   Gemini:  https://generativelanguage.googleapis.com/v1beta  (default)
#   OpenAI:  https://api.openai.com/v1
#   Groq:    https://api.groq.com/openai/v1
#   LocalAI: http://localhost:8080/v1
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Embedding model name — change when switching providers:
#   Gemini:  models/text-embedding-004  (default)
#   OpenAI:  text-embedding-3-small
#   Groq:    (use an OpenAI-compatible model name)
EMBEDDING_MODEL=models/text-embedding-004

# Database URL for knowledge items (PostgreSQL recommended for production)
KNOWLEDGE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/knowledge

# ── Shared Dependencies Version ───────────────────────────────────────────────
SOCIETYOPS_DEPENDENCIES_PACKAGE_VERSION=1.0.0
