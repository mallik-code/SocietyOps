# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/complaints.db
LOG_LEVEL=INFO
SQL_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ── AI Classifier (GROQ) ──────────────────────────────────────────────────────
# Leave blank to use the built-in keyword classifier (no API key needed)
GROQ_API_KEY=
# Default model — llama3-8b-8192 is fast and free-tier friendly
# Other options: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama3-8b-8192
