# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/complaints.db
LOG_LEVEL=INFO
SQL_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ── AI Classifier (GROQ) ──────────────────────────────────────────────────────
# Leave blank to use the built-in keyword classifier (no API key needed)
GROQ_API_KEY=
# Default model — llama3-8b-8192 is fast and free-tier friendly
# Other options: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama3-8b-8192

# ── OpenClaw Integration ───────────────────────────────────────────────────────
# Base URL of your OpenClaw instance
OPENCLAW_API_URL=https://api.openclaw.io
# API key for authenticating with OpenClaw (required to send reply messages)
OPENCLAW_API_KEY=
# Timeout in seconds for OpenClaw API calls
OPENCLAW_TIMEOUT=10

# ── Policy Engine ─────────────────────────────────────────────────────────────
# Set to true to disable all ticket creation and WhatsApp replies (log-only mode)
READ_ONLY_MODE=false

# Minimum AI confidence score required to create a ticket (0–1, default 0.7)
MIN_CONFIDENCE=0.7

# Send a polite reply even to non-complaint messages (default false)
ALLOW_CASUAL_REPLIES=false

# Hard-reject messages longer than this (characters)
MAX_MESSAGE_LENGTH=2000

# Comma-separated sender IDs/phones to allow, or * for all
ALLOWED_SENDERS=*

# Comma-separated keywords — messages containing any of these are rejected entirely
# Example: BLOCK_KEYWORDS=test,spam,advertisement
BLOCK_KEYWORDS=

# ── Daily Report Scheduler ────────────────────────────────────────────────────
# WhatsApp group ID that receives the daily report (required to actually send)
REPORT_GROUP_ID=
# Time to send the report in 24h format (default: 20:00 = 8 PM)
REPORT_CRON_HOUR=20
REPORT_CRON_MINUTE=0
# Timezone for the cron schedule — use any tz database name
# Examples: Asia/Karachi, Asia/Dubai, Asia/Kolkata, UTC, Europe/London
REPORT_TIMEZONE=Asia/Karachi

# ── Group Filtering ────────────────────────────────────────────────────────────
# Comma-separated list of allowed WhatsApp group IDs or group names.
# Accepts group IDs (e.g. 120363000000000001@g.us) or plain group names.
# Set to * or leave empty to allow ALL groups.
#
# Examples:
#   ALLOWED_GROUPS=*
#   ALLOWED_GROUPS=120363000000000001@g.us,120363000000000002@g.us
#   ALLOWED_GROUPS=Block B Residents,Tower A Complaints
ALLOWED_GROUPS=*
