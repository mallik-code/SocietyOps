# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/complaints.db
LOG_LEVEL=INFO
SQL_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ── AI Classifier (GROQ) ──────────────────────────────────────────────────────
# Leave blank to use the built-in keyword classifier (no API key needed)
GROQ_API_KEY=
# Default model — llama3-8b-8192 is fast and free-tier friendly
# Other options: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama3-8b-8192

# ── OpenClaw Integration ───────────────────────────────────────────────────────
# Base URL of your OpenClaw instance
OPENCLAW_API_URL=https://api.openclaw.io
# API key for authenticating with OpenClaw (required to send reply messages)
OPENCLAW_API_KEY=
# Timeout in seconds for OpenClaw API calls
OPENCLAW_TIMEOUT=10

# ── Group Filtering ────────────────────────────────────────────────────────────
# Comma-separated list of allowed WhatsApp group IDs or group names.
# Accepts group IDs (e.g. 120363000000000001@g.us) or plain group names.
# Set to * or leave empty to allow ALL groups.
#
# Examples:
#   ALLOWED_GROUPS=*
#   ALLOWED_GROUPS=120363000000000001@g.us,120363000000000002@g.us
#   ALLOWED_GROUPS=Block B Residents,Tower A Complaints
ALLOWED_GROUPS=*
