# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/complaints.db
LOG_LEVEL=INFO
SQL_ECHO=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ── AI Classifier (Claude) ────────────────────────────────────────────────────
# Leave blank to use the built-in keyword classifier (no API key needed)
ANTHROPIC_API_KEY=
# Default model — claude-3-haiku-20240307 is fast and cost-effective
# Other options: claude-3-5-sonnet-20241022, claude-3-opus-20240229
CLAUDE_MODEL=claude-3-haiku-20240307
