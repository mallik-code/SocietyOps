# Knowledge Engine Service Configuration

# Database Connection (PostgreSQL with pgvector)
# Example: postgresql+asyncpg://user:pass@localhost:5432/knowledge
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge

# Embedding Provider: gemini | openai | groq | generic
EMBEDDING_PROVIDER=gemini

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Generic / Groq / OpenAI Configuration
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false
